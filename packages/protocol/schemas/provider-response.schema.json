{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.globalpayto.dev/provider-response.schema.json",
  "title": "ProviderResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["providerIntentId", "status", "paymentInstruction"],
  "properties": {
    "providerIntentId": { "type": "string", "minLength": 1 },
    "status": { "const": "ready" },
    "paymentInstruction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "provider", "payload"],
      "properties": {
        "type": { "const": "provider_json" },
        "provider": { "type": "string", "minLength": 1 },
        "payload": { "$ref": "#/$defs/providerPayload" }
      }
    }
  },
  "$defs": {
    "providerPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["providerIntentId", "chain", "network", "asset", "recipientAddress", "amount", "reference", "expiresAt"],
      "properties": {
        "providerIntentId": { "type": "string", "minLength": 1 },
        "chain": { "type": "string", "minLength": 1 },
        "network": { "type": "string", "minLength": 1 },
        "asset": { "type": "string", "minLength": 1 },
        "recipientAddress": { "type": "string", "minLength": 1 },
        "amount": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "reference": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
